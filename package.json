    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.4.2",
    "jest-axe": "^10.0.0",
    "jest-environment-jsdom": "^30.4.1",
    "postcss": "^8.4.49",
    "prettier": "^3.9.6",
    "prettier-plugin-tailwindcss": "^0.8.1",
