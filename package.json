    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "framer-motion": "^11.11.9",
    "lucide-react": "^0.469.0",
    "next": "14.2.15",
